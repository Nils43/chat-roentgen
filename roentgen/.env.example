# Roentgen — local dev configuration.
# Copy to .env and fill in your own values.
# .env is gitignored. The API key never reaches the browser.

# --- Analyzer toggle ---
# 'fixture' (default) — serves pre-written profiles from /public/fixtures.
#                       Works without any API key. Perfect for UI/flow dev.
# 'api'               — calls the Anthropic API via /api/analyze. Needs key below.
VITE_ROENTGEN_ANALYZER=fixture

# --- Anthropic API key (only needed when VITE_ROENTGEN_ANALYZER=api) ---
ANTHROPIC_API_KEY=sk-ant-api03-...

# Set to 1 to surface proxy errors in the Vite terminal. Off by default to
# protect the no-logging promise.
# ROENTGEN_DEBUG=1

# --- Stripe (production on Vercel) ---
# Secret key — server-side only. Use test key (sk_test_…) during development.
STRIPE_SECRET_KEY=sk_test_...
# Webhook signing secret (Dashboard → Developers → Webhooks → endpoint).
# For local forwarding: `stripe listen --forward-to localhost:3000/api/stripe-webhook`
# prints one you can use.
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs for each unlock. Create them in the Stripe Dashboard:
#   Products → + New
#     Personal analysis   → price_...   (set STRIPE_PRICE_PROFILES)
#     Relationship analysis → price_...  (set STRIPE_PRICE_RELATIONSHIP)
#     Bundle              → price_...   (set STRIPE_PRICE_BUNDLE)
STRIPE_PRICE_PROFILES=price_...
STRIPE_PRICE_RELATIONSHIP=price_...
STRIPE_PRICE_BUNDLE=price_...

# --- Vercel KV (auto-set by `vercel env pull` once you add the KV integration
# in the Vercel dashboard). Required for webhook → unlock record storage. ---
# KV_URL=...
# KV_REST_API_URL=...
# KV_REST_API_TOKEN=...
# KV_REST_API_READ_ONLY_TOKEN=...

# --- PostHog (privacy-friendly funnel analytics, optional) ---
# Leave both unset to disable analytics entirely — client silently no-ops.
# Use the EU-hosted project so data stays in the EU.
# VITE_POSTHOG_KEY=phc_...
# VITE_POSTHOG_HOST=https://eu.i.posthog.com
